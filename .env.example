# Public Supabase project values. These are safe for the browser, but placeholders only here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this value to client components or browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical application origin, for example http://localhost:3000 in local development.
APP_BASE_URL=

# Never place real credentials in this file. Store local secrets in .env.local.
